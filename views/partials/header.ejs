<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Open Graph / Facebook WhatsApp Meta Tags (use these tags to generate rich link previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://theunpaidceo.co.uk" />
    <meta property="og:title" content="The Unpayed CEO" />
    <meta
      property="og:description"
      content="Empowering women to lead their lives and businesses with confidence, while balancing the demands of career, family, and self-care."
    />
    <meta
      property="og:image"
      content="https://theunpaidceo.co.uk/images/thumbnail.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter tags  -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="The Unpayed CEO" />
    <meta
      name="twitter:description"
      content="Empowering women to lead their lives and businesses with confidence, while balancing the demands of career, family, and self-care."
    />
    <meta
      name="twitter:image"
      content="https://theunpaidceo.co.uk/images/thumbnail.png"
    />

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/images/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/images/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/images/favicon.ico"
    />
    <!-- Bootstrap icons -->
    <!-- <link href="https://cdn.jsdelivr.net/npm/remixicon@4.0.0/fonts/remixicon.css" rel="stylesheet"> -->
    <!-- Boxicons Icons -->
    <link
      href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
      rel="stylesheet"
    />
    <!-- Quill Rich text editor -->
    <!-- <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet"> -->
    <!-- Tailwind CSS -->
    <link href="/styles/output.css" rel="stylesheet" />
    <link href="/styles/styles.css" rel="stylesheet" />
    <title>The Unpaid CEO</title>
  </head>
  <header class="bg-white shadow-sm">
    <div class="container mx-auto px-8 py-4 md:py-6">
      <div class="flex justify-between items-center">
        <a href="/" class="flex items-center">
          <img
            src="/images/logo-un-sm-gray.png"
            class="h-8 md:h-10"
            alt="The Unpaid CEO Logo"
          />
          <span class="text-2xl font-display font-bold text-gray-700">
            The <span class="text-teal-400">Unpaid </span>
            CEO
          </span>
        </a>
        <button class="lg:hidden" id="menuButton">
          <svg
            id="menuIcon"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-menu h-6 w-6 text-charcoal"
            data-id="element-104"
          >
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
          <svg
            id="closeIcon"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-x h-6 w-6 text-charcoal hidden"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
        <nav class="hidden lg:flex items-center space-x-8 text-xl">
          <a
            href="/"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Home</a
          >
          <a
            href="/about"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >About</a
          >
          <a
            href="/posts"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Blog</a
          >
          <a
            href="/resources"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Resources</a
          >
          <a
            href="/contact"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Contact</a
          >

          <!-- Conditional Login/Profile button -->
          <% if (user) { %>
            <!-- Profile dropdown for logged in users -->
             <div class="relative" id="profileDropdown">
              <button 
                onclick="toggleDropdown()" 
                class="flex items-center space-x-2 bg-teal-400 text-white px-4 py-2 rounded-md hover:bg-teal-400/80 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <span><%= user.name.split(' ')[0] %></span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>

              <!-- Dropdown menu -->
              <div id="dropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50 border border-gray-200">
                <a href="/profile" class="block px-4 py-2 text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors">
                  <div class="flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>My Profile</span>
                  </div>
                </a>
                <a href="/my-posts" class="block px-4 py-2 text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors">
                  <div class="flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                      <line x1="16" y1="13" x2="8" y2="13"></line>
                      <line x1="16" y1="17" x2="8" y2="17"></line>
                      <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>My Posts</span>
                  </div>
                </a>
                <a href="/createPostForm" class="block px-4 py-2 text-gray-700 hover:bg-teal-50 hover:text-teal-600 transition-colors">
                  <div class="flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 5v14"></path>
                      <path d="M5 12h14"></path>
                    </svg>
                    <span>Create Post</span>
                  </div>
                </a>
                <div class="border-t border-gray-200 my-1"></div>
                <a href="/logout" class="block px-4 py-2 text-gray-700 hover:bg-red-50 hover:text-red-600 transition-colors">
                  <div class="flex items-center space-x-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                      <polyline points="16 17 21 12 16 7"></polyline>
                      <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    <span>Logout</span>
                  </div>
                </a>
              </div>
            </div>
          <% } else { %>
          <a href="/login" class="bg-teal-400 text-white px-4 py-2 rounded-md hover:bg-teal-400/80 transition-colors flex items-center">Login</a>
          <% } %>
        </nav>
      </div>
      <!-- Mobile menu -->
      <nav
        class="hidden lg:hidden flex-col mt-4 space-y-3 pb-3"
        id="mobileMenu"
      >
        <div class="flex flex-col space-y-3 pb-3 pt-4">
          <a
            href="/"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Home</a
          >
          <a
            href="/about"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >About</a
          >
          <a
            href="/resources"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Resources</a
          >
          <a
            href="/contact"
            class="text-gray-700 hover:text-teal-400 transition-colors"
            >Contact</a
          >
          <% if (user) { %>
            <!-- Mobile menu for logged-in users -->
            <div class="border-t border-gray-200 my-2 pt-2">
              <div class="flex items-center space-x-3 py-2 mb-2 ">
                <div class="bg-teal-400  p-4 rounded-full border border-gray-200">
                  <span class="text-white text-xl  tracking-wide">
                    <%= user.name.split(' ').map((item) => item.charAt(0)).join('').toUpperCase() %>
                  </span>
                  
                </div>
                <div class="flex flex-col">
                  <p class="text-sm font-medium text-charcoal">Hello, <%= user.name %></p>
                  <p class="text-xs text-gray-500"><%= user.email %></p>
                </div>
                
              </div>
              
              <a href="/profile" class="block text-gray-700 hover:text-teal-400 transition-colors py-2">My Profile</a>
              <a href="/my-posts" class="block text-gray-700 hover:text-teal-400 transition-colors py-2">My Posts</a>
              <a href="/createPostForm" class="block text-gray-700 hover:text-teal-400 transition-colors py-2">Create Post</a>
              <a href="/logout" class="block text-red-600 hover:text-red-700 transition-colors py-2">Logout</a>
            </div>
          <% } else { %>
            <!-- Mobile menu for guests -->
            <a
              href="/login"
              class="bg-teal-400 text-white px-4 py-2 rounded-md hover:bg-teal-400/80 transition-colors flex items-center w-fit"
            >
              Login
            </a>
          <% } %>
          <!-- <a
            href="/createPostForm"
            class="bg-teal-400 text-white px-4 py-2 rounded-md hover:bg-teal-400/80 transition-colors flex items-center w-fit"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-plus h-4 w-4 mr-2"
              data-id="element-111"
            >
              <path d="M5 12h14"></path>
              <path d="M12 5v14"></path>
            </svg>
            Create Post
          </a> -->
        </div>
      </nav>
    </div>
  </header>

