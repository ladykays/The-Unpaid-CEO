<%- include("partials/header.ejs") %>
<main class="flex-grow">
  <div class="pb-16">
    <!-- Hero Section -->
    <section class="bg-gray-900 text-white py-20 relative">
      <div class="container mx-auto px-8 text-center">
        <h1 class="text-5xl lg:text-6xl font-display font-bold mb-9">
          Welcome to<span class="text-teal-400"> The Unpaid CEO</span>
        </h1>
        <p class="text-2xl max-w-2xl mx-auto text-gray-200">
          Join our community of women redefining success on their own terms.
        </p>
      </div>
    </section>
    <!-- Login/Signup section -->
    <section class="relative z-10 -mt-8 flex justify-center px-4">
      <div class="bg-white rounded-xl shadow-lg shadow-gray-400 w-full max-w-md md:max-w-lg mx-auto overflow-hidden">
        <!-- Tabs -->
        <div class="flex border-b border-gray-200">
          <button 
            id="loginTab"
            class="flex-1 py-4 text-center font-medium bg-teal-50 text-teal-600 border-b-2 border-teal-500 cursor-pointer"
            onclick="showLogin()"
          >Log In</button>
          <button 
            id="signupTab"
            class="flex-1 py-4 text-center font-medium text-gray-500 hover:text-gray-700 cursor-pointer" 
            onclick="showSignup()"
          >Sign Up</button>
        </div>
        
        <!-- Login Content -->
        <div id="loginForm"  class="p-6 md:p-8">
          <!-- Social Login Buttons -->
          <div class="space-y-3">
            <button class="w-full flex items-center justify-center gap-2 bg-white border border-gray-300 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-50 transition cursor-pointer">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Continue with Google
            </button>
            
            <button class="w-full flex items-center justify-center gap-2 bg-[#1877F2] text-white py-3 px-4 rounded-lg hover:bg-[#166FE5] transition cursor-pointer">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Continue with Facebook
            </button>
            
            <button class="w-full flex items-center justify-center gap-2 bg-black text-white py-3 px-4 rounded-lg hover:bg-gray-900 transition cursor-pointer">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Continue with X
            </button>
          </div>

          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-white text-gray-500">or continue with email</span>
            </div>
          </div>
          
          <!-- Signup Form -->
          <form action="/login" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
              <input type="email" value="<%#= email %>" placeholder="✉️ you@example.com" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent">
            </div>
            
            <div>
              <span class="flex justify-between">
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <a href="#" class="text-teal-500">Forgot password?</a>
              </span>
              
              <input type="password" value="<%#= password %>" placeholder="🔒 *********" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent">
            </div>
            
            <button type="submit" class="w-full bg-teal-500 text-white py-3 px-4 rounded-lg font-medium hover:bg-teal-600 transition cursor-pointer">
              Log In →
            </button>
          </form>
        </div>

        <!-- Sign Up Form Content -->
        <div id="signupForm" class="p-6 md:p-8 hidden">
          <!-- Social Login Buttons -->
          <div class="space-y-3">
            <button class="w-full flex items-center justify-center gap-2 bg-white border border-gray-300 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-50 transition cursor-pointer">
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Continue with Google
            </button>
            
            <button class="w-full flex items-center justify-center gap-2 bg-[#1877F2] text-white py-3 px-4 rounded-lg hover:bg-[#166FE5] transition cursor-pointer">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Continue with Facebook
            </button>
            
            <button class="w-full flex items-center justify-center gap-2 bg-black text-white py-3 px-4 rounded-lg hover:bg-gray-900 transition cursor-pointer">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              Continue with X
            </button>
          </div>
          
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-gray-300"></div>
            </div>
            <div class="relative flex justify-center text-sm">
              <span class="px-2 bg-white text-gray-500">or continue with email</span>
            </div>
          </div>
          
          <!-- Email Signup Form -->
          <form action="/signup" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
              <input type="text" value="<%#= fullName %>" placeholder="👤 Amanda Adams" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent">
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
              <input type="email" value="<%#= email %>" placeholder="✉️ you@example.com" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent">
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
              <input type="password" value="<%#= password %>" placeholder="🔒 ********" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent">
            </div>
            
            <button type="submit" class="w-full bg-teal-500 text-white py-3 px-4 rounded-lg font-medium hover:bg-teal-600 transition cursor-pointer">
              Create Account →
            </button>
          </form>
          
          <p class="text-xs text-gray-500 text-center mt-4">
            By signing up, you agree to our <a href="#" class="text-teal-600 hover:underline">Terms of Service</a> and <a href="#" class="text-teal-600 hover:underline">Privacy Policy</a>.
          </p>
        </div>

        
      </div>
    </section>
  </div>
</main>

<script>
  function showLogin() {
  // Hide signup form, show login form
  document.getElementById("signupForm").classList.add("hidden");
  document.getElementById("loginForm").classList.remove("hidden");

  // Update tab styles
  document.getElementById("loginTab").classList.add("text-teal-600", "bg-teal-50", "border-b-2", "border-teal-500");
  document.getElementById("loginTab").classList.remove("text-gray-500");
  document.getElementById("signupTab").classList.remove("text-teal-600", "bg-teal-50", "border-b-2", "border-teal-500");
  document.getElementById("signupTab").classList.add("text-gray-500");
}

function showSignup() {
  // Hide login form, show signup form
  document.getElementById("loginForm").classList.add("hidden");
  document.getElementById("signupForm").classList.remove("hidden");

  // Update tab styles
  document.getElementById("signupTab").classList.add("text-teal-600", "bg-teal-50", "border-b-2", "border-teal-500");
  document.getElementById("signupTab").classList.remove("text-gray-500");
  document.getElementById("loginTab").classList.remove("text-teal-600", "bg-teal-50", "border-b-2", "border-teal-500");
  document.getElementById("loginTab").classList.add("text-gray-500");
}
</script>
